# MongoDB (matches docker-compose.yml)
MONGO_URL=mongodb://localhost:27017/fuzzy_assessment

# Redis powers BullMQ sequence sending jobs.
REDIS_HOST=localhost
REDIS_PORT=6379

# ── LLM provider ───────────────────────────────────────────────────────────
# Use whatever you already have a key for. Set LLM_PROVIDER to one of:
#   anthropic | openai | gemini
# ...then fill in the matching API key below. All three SDKs are pre-installed.
LLM_PROVIDER=anthropic

# Provide ONLY the key for the provider you chose:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional overrides. Leave LLM_MODEL blank to use a sensible cheap default per
# provider (claude-haiku-4-5 / gpt-4o-mini / gemini-1.5-flash).
LLM_MODEL=
LLM_MAX_TOKENS=300

PORT=8080
AUTH_SECRET=replace-with-a-long-random-local-secret

# Frontend origin allowed by CORS. Change if Next starts on a different port.
FRONTEND_ORIGIN=http://localhost:3000
